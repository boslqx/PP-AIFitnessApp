<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Update your profile and targets"
            android:textSize="13sp"
            android:textColor="#9E9E9E"
            android:layout_marginBottom="24dp"/>

        <!-- ── SECTION: PERSONAL INFO ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👤  PERSONAL INFO"
            android:textSize="11sp"
            android:textColor="#388E3C"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Name"
                android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSettingsName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"/>
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gender"
                android:textSize="13sp"
                android:textColor="#757575"
                android:layout_marginBottom="8dp"/>

            <RadioGroup
                android:id="@+id/rgSettingsGender"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <RadioButton
                    android:id="@+id/rbSettingsMale"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Male"
                    android:tag="male"
                    android:gravity="center"
                    android:button="@null"
                    android:background="@drawable/selector_gender_btn"
                    android:layout_marginEnd="8dp"/>

                <RadioButton
                    android:id="@+id/rbSettingsFemale"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Female"
                    android:tag="female"
                    android:gravity="center"
                    android:button="@null"
                    android:background="@drawable/selector_gender_btn"/>

            </RadioGroup>

        </LinearLayout>

        <!-- ── SECTION: BODY METRICS ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📏  BODY METRICS"
            android:textSize="11sp"
            android:textColor="#388E3C"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Age"
                    android:layout_marginEnd="8dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSettingsAge"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Height (cm)">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSettingsHeight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"/>
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Current weight (kg)"
                    android:layout_marginEnd="8dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSettingsWeight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Target weight (kg)">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSettingsTargetWeight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"/>
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- ── SECTION: ACTIVITY LEVEL ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏃  ACTIVITY LEVEL"
            android:textSize="11sp"
            android:textColor="#388E3C"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp"
            android:layout_marginBottom="16dp">

            <RadioGroup
                android:id="@+id/rgSettingsActivity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbSetSedentary"
                    style="@style/ActivityLevelOption"
                    android:text="🪑  Sedentary — desk job, little exercise"
                    android:tag="sedentary"/>

                <RadioButton
                    android:id="@+id/rbSetLight"
                    style="@style/ActivityLevelOption"
                    android:text="🚶  Light — exercise 1–3 days/week"
                    android:tag="light"/>

                <RadioButton
                    android:id="@+id/rbSetModerate"
                    style="@style/ActivityLevelOption"
                    android:text="🏃  Moderate — exercise 3–5 days/week"
                    android:tag="moderate"/>

                <RadioButton
                    android:id="@+id/rbSetActive"
                    style="@style/ActivityLevelOption"
                    android:text="💪  Active — hard exercise 6–7 days/week"
                    android:tag="active"/>

                <RadioButton
                    android:id="@+id/rbSetVeryActive"
                    style="@style/ActivityLevelOption"
                    android:text="🔥  Very Active — physical job + training"
                    android:tag="very_active"/>

            </RadioGroup>

        </LinearLayout>

        <!-- ── SECTION: FITNESS GOAL ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎯  FITNESS GOAL"
            android:textSize="11sp"
            android:textColor="#388E3C"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp"
            android:layout_marginBottom="16dp">

            <RadioGroup
                android:id="@+id/rgSettingsGoal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <RadioButton
                    android:id="@+id/rbSetFatLoss"
                    style="@style/ActivityLevelOption"
                    android:text="🔥  Fat Loss — burn fat, get lean"
                    android:tag="fat_loss"/>

                <RadioButton
                    android:id="@+id/rbSetMuscleGain"
                    style="@style/ActivityLevelOption"
                    android:text="💪  Muscle Gain — build strength and size"
                    android:tag="muscle_gain"/>

                <RadioButton
                    android:id="@+id/rbSetEndurance"
                    style="@style/ActivityLevelOption"
                    android:text="🏃  Endurance — improve stamina and fitness"
                    android:tag="endurance"/>

            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Timeline"
                android:textSize="13sp"
                android:textColor="#757575"
                android:layout_marginBottom="8dp"/>

            <RadioGroup
                android:id="@+id/rgSettingsTimeline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rbSet3Months"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="3 Months"
                    android:tag="3"
                    android:gravity="center"
                    android:button="@null"
                    android:background="@drawable/selector_gender_btn"
                    android:layout_marginEnd="8dp"/>

                <RadioButton
                    android:id="@+id/rbSet6Months"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="6 Months"
                    android:tag="6"
                    android:gravity="center"
                    android:button="@null"
                    android:background="@drawable/selector_gender_btn"/>

            </RadioGroup>

        </LinearLayout>

        <!-- AI RECALCULATION PREVIEW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E8F5E9"
            android:padding="20dp"
            android:elevation="2dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🤖  NEW AI TARGETS"
                android:textSize="11sp"
                android:textColor="#388E3C"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvNewTargets"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fill in your details above to preview new targets."
                android:textSize="14sp"
                android:textColor="#1B5E20"
                android:lineSpacingMultiplier="1.5"
                android:fontFamily="monospace"/>

        </LinearLayout>

        <!-- SAVE BUTTON -->
        <Button
            android:id="@+id/btnSaveSettings"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save &amp; Recalculate Targets"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <!-- BACK BUTTON -->
        <Button
            android:id="@+id/btnBackFromSettings"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:text="← Back to Dashboard"/>

    </LinearLayout>
</ScrollView>