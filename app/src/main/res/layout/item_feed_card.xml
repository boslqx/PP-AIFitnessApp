<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/md_theme_outlineVariant"
    app:strokeWidth="1dp"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Photo — full width, hidden if none -->
        <ImageView
            android:id="@+id/ivFeedPhoto"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:visibility="gone"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header row: emoji + title + date -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvFeedEmoji"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="🏋️"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:background="@color/md_theme_surfaceContainer"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvFeedTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Moderate Gym — Strength"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/md_theme_onSurface"/>

                    <TextView
                        android:id="@+id/tvFeedDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thu, Mar 20"
                        android:textSize="12sp"
                        android:textColor="@color/md_theme_onSurfaceVariant"
                        android:layout_marginTop="2dp"/>

                </LinearLayout>

                <!-- Status badge -->
                <TextView
                    android:id="@+id/tvFeedStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅"
                    android:textSize="20sp"/>

            </LinearLayout>

            <!-- Effort dots -->
            <TextView
                android:id="@+id/tvFeedEffort"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="●●●○○  Moderate"
                android:textSize="12sp"
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:fontFamily="monospace"
                android:layout_marginBottom="8dp"
                android:visibility="gone"/>

            <!-- Exercises preview -->
            <LinearLayout
                android:id="@+id/feedExerciseContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

            <!-- Overflow label -->
            <TextView
                android:id="@+id/tvFeedMoreExercises"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ 2 more"
                android:textSize="12sp"
                android:textColor="@color/md_theme_primary"
                android:layout_marginTop="4dp"
                android:visibility="gone"/>

        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>