<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your AI Plan"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Personalized for your performance"
            android:textSize="13sp"
            android:textColor="#9E9E9E"
            android:layout_marginBottom="20dp"/>

        <!-- PLAN HEADER CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1B5E20"
            android:padding="24dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvPlanTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Steady Progress"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvPlanDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textSize="13sp"
                android:textColor="#A5D6A7"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="16dp"/>

            <!-- Adaptation note -->
            <TextView
                android:id="@+id/tvAdaptationNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="#2E7D32"
                android:padding="12dp"/>

        </LinearLayout>

        <!-- STATS ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:gravity="center"
                android:layout_marginEnd="6dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TARGET"
                    android:textSize="10sp"
                    android:textColor="#9E9E9E"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tvPlanTarget"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4 days"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#212121"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:gravity="center"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SCORE BASIS"
                    android:textSize="10sp"
                    android:textColor="#9E9E9E"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tvPlanScoreBasis"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="72 / 100"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#212121"/>

            </LinearLayout>

        </LinearLayout>

        <!-- 7-DAY PLAN LIST -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📅  THIS WEEK"
            android:textSize="11sp"
            android:textColor="#388E3C"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:id="@+id/planDayContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp"/>

        <!-- BACK BUTTON -->
        <Button
            android:id="@+id/btnBackFromPlan"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:text="← Back to Dashboard"/>

    </LinearLayout>
</ScrollView>