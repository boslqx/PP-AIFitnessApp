<?xml version="1.0" encoding="utf-8"?>
<!--
    item_history_row.xml
    One row in the Progress screen's workout history list.

    LAYOUT STRUCTURE:
    [Thumbnail/Icon] | [Date + Title] | [Effort dots]

    The thumbnail (ivHistoryPhoto) and the emoji icon (tvHistoryIcon)
    occupy the same 40×40dp slot on the left.
    - If a photo exists: show thumbnail, hide emoji icon
    - If no photo:       show emoji icon, hide thumbnail

    WHY this approach instead of overlapping views?
    Using GONE/VISIBLE is simpler and more performant than
    FrameLayout overlapping. Only one view takes up space at a time.
    The row height stays consistent either way.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp"
    android:layout_marginBottom="2dp">

    <!--
        ICON SLOT — either emoji or photo thumbnail.
        Both are 40×40dp so the row width never changes.
    -->

    <!-- Emoji icon — shown when no photo exists -->
    <TextView
        android:id="@+id/tvHistoryIcon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:text="🏋️"
        android:textSize="20sp"
        android:gravity="center"
        android:background="@color/md_theme_surfaceContainer"
        android:layout_marginEnd="12dp"/>

    <!--
        Photo thumbnail — shown when a photo exists.
        Starts GONE. Java code sets it VISIBLE and loads the image.

        scaleType="centerCrop":
        Crops the image to fill the square without distortion.
        This is the correct scale type for thumbnails — it always
        fills the space cleanly regardless of photo orientation.
    -->
    <ImageView
        android:id="@+id/ivHistoryPhoto"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:scaleType="centerCrop"
        android:layout_marginEnd="12dp"
        android:visibility="gone"/>

    <!-- DATE + SESSION TITLE -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvHistoryDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mon, Mar 17"
            android:textSize="11sp"
            android:textColor="@color/md_theme_onSurfaceVariant"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/tvHistoryTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✅  Moderate Gym — Strength"
            android:textSize="13sp"
            android:textColor="@color/md_theme_onSurface"/>

    </LinearLayout>

    <!-- EFFORT DOTS e.g. ●●●○○ -->
    <TextView
        android:id="@+id/tvHistoryEffort"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="●●●○○"
        android:textSize="12sp"
        android:textColor="@color/md_theme_primary"
        android:fontFamily="monospace"/>

</LinearLayout>