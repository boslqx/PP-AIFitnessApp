<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_surface"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/homeScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- HEADER -->
            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Good morning 👋"
                android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                android:textColor="@color/md_theme_onSurface"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvWeekLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Week 1 · Day 1"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:layout_marginBottom="20dp"/>

            <!-- WEEK STRIP CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/md_theme_outlineVariant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:id="@+id/weekStrip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"/>

            </com.google.android.material.card.MaterialCardView>

            <!-- TODAY CARD -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardToday"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/md_theme_primary"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TODAY'S FOCUS"
                        android:textSize="11sp"
                        android:textColor="#C8D3FF"
                        android:textAllCaps="true"
                        android:letterSpacing="0.15"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:id="@+id/tvTodayEmoji"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:text="🏋️"
                            android:textSize="28sp"
                            android:gravity="center"
                            android:background="#4D5D9E"
                            android:layout_marginEnd="16dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvTodayTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Moderate Gym — Strength"
                                android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/tvTodayIntensity"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Moderate  ·  60 min"
                                android:textSize="13sp"
                                android:textColor="#C8D3FF"
                                android:layout_marginTop="2dp"/>

                            <TextView
                                android:id="@+id/tvTodayDuration"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:visibility="gone"/>

                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvTodayDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="4×5 Squat · Bench press · Row"
                        android:textSize="13sp"
                        android:textColor="#E1E8FF"
                        android:lineSpacingMultiplier="1.4"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:id="@+id/tvTodayCoachNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Week 1 — focus on form."
                        android:textSize="12sp"
                        android:textColor="#A8B4FF"
                        android:layout_marginBottom="20dp"/>

                    <TextView
                        android:id="@+id/tvAlreadyLogged"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✅ Logged today"
                        android:textSize="13sp"
                        android:textColor="#A5D6A7"
                        android:visibility="gone"
                        android:layout_marginBottom="8dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStartWorkout"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Start Workout →"
                        android:textAllCaps="false"
                        android:textSize="15sp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRestDay"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="😴  Mark Rest Day"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:visibility="gone"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- FEED LABEL -->
            <TextView
                android:id="@+id/tvFeedLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RECENT WORKOUTS"
                android:textSize="11sp"
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:textAllCaps="true"
                android:letterSpacing="0.15"
                android:layout_marginBottom="12dp"
                android:visibility="gone"/>

            <!-- FEED CONTAINER -->
            <LinearLayout
                android:id="@+id/feedContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  BOTTOM NAV BAR — 5 tabs, icons only                  -->
    <!--                                                        -->
    <!--  Icons only (no text) so 5 buttons fit comfortably.   -->
    <!--  Each button is an emoji — no vector drawable needed.  -->
    <!--  Active tab is highlighted with primary color tint     -->
    <!--  in HomeActivity.java.                                 -->
    <!-- ══════════════════════════════════════════════════════ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="0dp"
        app:cardElevation="8dp"
        app:strokeColor="@color/md_theme_outlineVariant"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center">

            <!--
                Each button: emoji only, equal weight, no text.
                textSize="22sp" makes emojis large enough to tap easily.
                minWidth="0dp" prevents Material button enforcing a minimum.
                paddingStart/End="0dp" removes extra lateral padding.
            -->

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNavLog"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="📝"
                android:textSize="22sp"
                android:minWidth="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:contentDescription="Log"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNavPlan"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="📅"
                android:textSize="22sp"
                android:minWidth="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:contentDescription="Plan"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNavProgress"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="📈"
                android:textSize="22sp"
                android:minWidth="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:contentDescription="Progress"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNavCoach"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="🤖"
                android:textSize="22sp"
                android:minWidth="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:contentDescription="Coach"/>

            <!-- 5th tab: Settings -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNavSettings"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="⚙️"
                android:textSize="22sp"
                android:minWidth="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:contentDescription="Settings"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>