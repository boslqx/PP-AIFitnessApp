<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Big checkmark -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✅"
            android:textSize="64sp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Log Saved!"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvSummaryDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thursday, March 12"
            android:textSize="14sp"
            android:textColor="#9E9E9E"
            android:layout_marginBottom="32dp"/>

        <!-- WORKOUT SUMMARY -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:elevation="2dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏋️  WORKOUT"
                android:textSize="11sp"
                android:textColor="#388E3C"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvSummaryWorkoutType"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Strength"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#212121"/>

                <TextView
                    android:id="@+id/tvSummaryWorkoutDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="45 min"
                    android:textSize="14sp"
                    android:textColor="#757575"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvSummaryCaloriesBurned"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="~320 kcal burned"
                android:textSize="13sp"
                android:textColor="#4CAF50"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- NUTRITION SUMMARY -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:elevation="2dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🥗  NUTRITION"
                android:textSize="11sp"
                android:textColor="#388E3C"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tvSummaryCalories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1,840 kcal"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="8dp"/>

            <!-- vs target -->
            <TextView
                android:id="@+id/tvSummaryCalorieVsTarget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅ On target"
                android:textSize="13sp"
                android:textColor="#4CAF50"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvSummaryProtein"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Protein\n0g"
                    android:gravity="center"
                    android:textSize="13sp"
                    android:textColor="#757575"/>

                <TextView
                    android:id="@+id/tvSummaryCarbs"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Carbs\n0g"
                    android:gravity="center"
                    android:textSize="13sp"
                    android:textColor="#757575"/>

                <TextView
                    android:id="@+id/tvSummaryFat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Fat\n0g"
                    android:gravity="center"
                    android:textSize="13sp"
                    android:textColor="#757575"/>
            </LinearLayout>
        </LinearLayout>

        <!-- SLEEP + WATER + MOOD ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- Sleep -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:elevation="2dp"
                android:gravity="center"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="😴"
                    android:textSize="24sp"/>

                <TextView
                    android:id="@+id/tvSummarySleep"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="7h"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#212121"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="sleep"
                    android:textSize="11sp"
                    android:textColor="#9E9E9E"/>
            </LinearLayout>

            <!-- Water -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:elevation="2dp"
                android:gravity="center"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💧"
                    android:textSize="24sp"/>

                <TextView
                    android:id="@+id/tvSummaryWater"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2L"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#212121"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="water"
                    android:textSize="11sp"
                    android:textColor="#9E9E9E"/>
            </LinearLayout>

            <!-- Mood -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:elevation="2dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvSummaryMoodEmoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="😊"
                    android:textSize="24sp"/>

                <TextView
                    android:id="@+id/tvSummaryMood"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Great"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#212121"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="mood"
                    android:textSize="11sp"
                    android:textColor="#9E9E9E"/>
            </LinearLayout>

        </LinearLayout>

        <!-- AI FEEDBACK CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E8F5E9"
            android:padding="20dp"
            android:elevation="2dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💡  AI FEEDBACK"
                android:textSize="11sp"
                android:textColor="#388E3C"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvSummaryAiFeedback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Great job logging today!"
                android:textSize="14sp"
                android:textColor="#1B5E20"
                android:lineSpacingMultiplier="1.4"/>
        </LinearLayout>

        <!-- BACK TO DASHBOARD BUTTON -->
        <Button
            android:id="@+id/btnBackToDashboard"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Back to Dashboard"
            android:textSize="16sp"/>

    </LinearLayout>
</ScrollView>