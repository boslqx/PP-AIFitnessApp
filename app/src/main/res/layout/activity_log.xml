<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_surface"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LOG WORKOUT"
                    android:textSize="11sp"
                    android:textColor="@color/md_theme_primary"
                    android:textAllCaps="true"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvLogSessionTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Moderate Gym — Strength"
                    android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                    android:textColor="@color/md_theme_onSurface"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvLogActivityType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏋️  Gym"
                    android:textSize="14sp"
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBackFromLog"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕"
                android:textSize="18sp"
                android:textColor="@color/md_theme_onSurfaceVariant"/>

        </LinearLayout>

        <!-- EXERCISES SECTION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Exercises"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textColor="@color/md_theme_onSurface"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tick what you completed. Tap ✏️ to edit sets/reps."
            android:textSize="12sp"
            android:textColor="@color/md_theme_onSurfaceVariant"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/md_theme_outlineVariant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:id="@+id/exerciseListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp"/>

        </com.google.android.material.card.MaterialCardView>

        <!-- ADD EXERCISE BUTTON -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddExercise"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="24dp"
            android:text="+ Add Exercise"
            android:textAllCaps="false"/>

        <!-- EFFORT SECTION -->
        <LinearLayout
            android:id="@+id/sectionEffort"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="How hard did it feel?"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="@color/md_theme_onSurface"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="The AI uses this to adjust next week's intensity"
                android:textSize="12sp"
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/md_theme_outlineVariant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RadioGroup
                        android:id="@+id/rgEffort"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <RadioButton android:id="@+id/rbEff1"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:text="1"
                            android:gravity="center"
                            android:button="@null"
                            android:background="@drawable/selector_gender_btn"
                            android:layout_marginEnd="4dp"/>

                        <RadioButton android:id="@+id/rbEff2"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:text="2"
                            android:gravity="center"
                            android:button="@null"
                            android:background="@drawable/selector_gender_btn"
                            android:layout_marginEnd="4dp"/>

                        <RadioButton android:id="@+id/rbEff3"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:text="3"
                            android:gravity="center"
                            android:button="@null"
                            android:background="@drawable/selector_gender_btn"
                            android:layout_marginEnd="4dp"/>

                        <RadioButton android:id="@+id/rbEff4"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:text="4"
                            android:gravity="center"
                            android:button="@null"
                            android:background="@drawable/selector_gender_btn"
                            android:layout_marginEnd="4dp"/>

                        <RadioButton android:id="@+id/rbEff5"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:text="5"
                            android:gravity="center"
                            android:button="@null"
                            android:background="@drawable/selector_gender_btn"/>

                    </RadioGroup>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Very Easy"
                            android:textSize="10sp"
                            android:textColor="@color/md_theme_onSurfaceVariant"
                            android:gravity="start"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Very Hard"
                            android:textSize="10sp"
                            android:textColor="@color/md_theme_onSurfaceVariant"
                            android:gravity="end"/>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- PHOTO SECTION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Photo"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textColor="@color/md_theme_onSurface"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/md_theme_outlineVariant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center">

                <!-- Photo preview — hidden until photo selected -->
                <ImageView
                    android:id="@+id/ivPhotoPreview"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tvPhotoLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Record your progress — optional"
                    android:textSize="13sp"
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddPhoto"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="📷  Add Photo"
                    android:textAllCaps="false"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- NOTES SECTION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Notes (optional)"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textColor="@color/md_theme_onSurface"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. Felt strong today, increased bench weight"
            android:layout_marginBottom="32dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:gravity="top"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- SAVE BUTTON -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveLog"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save Log ✅"
            android:textSize="16sp"
            android:textAllCaps="false"/>

    </LinearLayout>
</ScrollView>