<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvLogTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Log Today"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#212121"/>

            <TextView
                android:id="@+id/tvLogDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thursday, March 12"
                android:textSize="12sp"
                android:textColor="#9E9E9E"/>
        </LinearLayout>

        <!-- ── SECTION 1: WORKOUT ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏋️  WORKOUT"
            android:textSize="12sp"
            android:textColor="#388E3C"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp"
            android:layout_marginBottom="16dp">

            <!-- Workout type buttons -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Type"
                android:textSize="13sp"
                android:textColor="#757575"
                android:layout_marginBottom="8dp"/>

            <RadioGroup
                android:id="@+id/rgWorkoutType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <RadioButton android:id="@+id/rbStrength"
                    android:layout_width="0dp" android:layout_height="40dp"
                    android:layout_weight="1" android:text="💪 Strength"
                    android:tag="strength" android:gravity="center"
                    android:button="@null" android:textSize="11sp"
                    android:background="@drawable/selector_gender_btn"
                    android:layout_marginEnd="4dp"/>

                <RadioButton android:id="@+id/rbCardio"
                    android:layout_width="0dp" android:layout_height="40dp"
                    android:layout_weight="1" android:text="🏃 Cardio"
                    android:tag="cardio" android:gravity="center"
                    android:button="@null" android:textSize="11sp"
                    android:background="@drawable/selector_gender_btn"
                    android:layout_marginEnd="4dp"/>

                <RadioButton android:id="@+id/rbFlexibility"
                    android:layout_width="0dp" android:layout_height="40dp"
                    android:layout_weight="1" android:text="🧘 Flex"
                    android:tag="flexibility" android:gravity="center"
                    android:button="@null" android:textSize="11sp"
                    android:background="@drawable/selector_gender_btn"
                    android:layout_marginEnd="4dp"/>

                <RadioButton android:id="@+id/rbRest"
                    android:layout_width="0dp" android:layout_height="40dp"
                    android:layout_weight="1" android:text="😴 Rest"
                    android:tag="rest" android:gravity="center"
                    android:button="@null" android:textSize="11sp"
                    android:background="@drawable/selector_gender_btn"/>
            </RadioGroup>

            <!-- Duration -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Duration (minutes)"
                android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDuration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Intensity -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Intensity"
                android:textSize="13sp"
                android:textColor="#757575"
                android:layout_marginBottom="8dp"/>

            <RadioGroup
                android:id="@+id/rgIntensity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton android:id="@+id/rbInt1"
                    android:layout_width="0dp" android:layout_height="40dp"
                    android:layout_weight="1" android:text="1"
                    android:tag="1" android:gravity="center"
                    android:button="@null"
                    android:background="@drawable/selector_gender_btn"
                    android:layout_marginEnd="3dp"/>
                <RadioButton android:id="@+id/rbInt2"
                    android:layout_width="0dp" android:layout_height="40dp"
                    android:layout_weight="1" android:text="2"
                    android:tag="2" android:gravity="center"
                    android:button="@null"
                    android:background="@drawable/selector_gender_btn"
                    android:layout_marginEnd="3dp"/>
                <RadioButton android:id="@+id/rbInt3"
                    android:layout_width="0dp" android:layout_height="40dp"
                    android:layout_weight="1" android:text="3"
                    android:tag="3" android:gravity="center"
                    android:button="@null"
                    android:background="@drawable/selector_gender_btn"
                    android:layout_marginEnd="3dp"/>
                <RadioButton android:id="@+id/rbInt4"
                    android:layout_width="0dp" android:layout_height="40dp"
                    android:layout_weight="1" android:text="4"
                    android:tag="4" android:gravity="center"
                    android:button="@null"
                    android:background="@drawable/selector_gender_btn"
                    android:layout_marginEnd="3dp"/>
                <RadioButton android:id="@+id/rbInt5"
                    android:layout_width="0dp" android:layout_height="40dp"
                    android:layout_weight="1" android:text="5"
                    android:tag="5" android:gravity="center"
                    android:button="@null"
                    android:background="@drawable/selector_gender_btn"/>
            </RadioGroup>

        </LinearLayout>

        <!-- ── SECTION 2: NUTRITION ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🥗  NUTRITION"
            android:textSize="12sp"
            android:textColor="#388E3C"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Morning weight (kg) — optional"
                android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etWeight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Calories (kcal)"
                android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCalories"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Macro row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Protein (g)"
                    android:layout_marginEnd="6dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etProtein"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Carbs (g)"
                    android:layout_marginEnd="6dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCarbs"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Fat (g)">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etFat"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"/>
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </LinearLayout>

        <!-- ── SECTION 3: SLEEP ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="😴  SLEEP"
            android:textSize="12sp"
            android:textColor="#388E3C"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Hours slept (e.g. 7)"
                android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSleepHours"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"/>
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sleep quality"
                android:textSize="13sp"
                android:textColor="#757575"
                android:layout_marginBottom="8dp"/>

            <RadioGroup
                android:id="@+id/rgSleepQuality"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton android:id="@+id/rbSq1"
                    android:layout_width="0dp" android:layout_height="40dp"
                    android:layout_weight="1" android:text="😫"
                    android:tag="1" android:gravity="center"
                    android:button="@null"
                    android:background="@drawable/selector_gender_btn"
                    android:layout_marginEnd="4dp"/>
                <RadioButton android:id="@+id/rbSq2"
                    android:layout_width="0dp" android:layout_height="40dp"
                    android:layout_weight="1" android:text="😕"
                    android:tag="2" android:gravity="center"
                    android:button="@null"
                    android:background="@drawable/selector_gender_btn"
                    android:layout_marginEnd="4dp"/>
                <RadioButton android:id="@+id/rbSq3"
                    android:layout_width="0dp" android:layout_height="40dp"
                    android:layout_weight="1" android:text="😐"
                    android:tag="3" android:gravity="center"
                    android:button="@null"
                    android:background="@drawable/selector_gender_btn"
                    android:layout_marginEnd="4dp"/>
                <RadioButton android:id="@+id/rbSq4"
                    android:layout_width="0dp" android:layout_height="40dp"
                    android:layout_weight="1" android:text="😊"
                    android:tag="4" android:gravity="center"
                    android:button="@null"
                    android:background="@drawable/selector_gender_btn"
                    android:layout_marginEnd="4dp"/>
                <RadioButton android:id="@+id/rbSq5"
                    android:layout_width="0dp" android:layout_height="40dp"
                    android:layout_weight="1" android:text="😴"
                    android:tag="5" android:gravity="center"
                    android:button="@null"
                    android:background="@drawable/selector_gender_btn"/>
            </RadioGroup>

        </LinearLayout>

        <!-- ── SECTION 4: WATER ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💧  WATER"
            android:textSize="12sp"
            android:textColor="#388E3C"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Water intake (ml, e.g. 2000)">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etWater"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"/>
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- ── SECTION 5: MOOD ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🧠  MOOD"
            android:textSize="12sp"
            android:textColor="#388E3C"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp"
            android:layout_marginBottom="24dp">

            <RadioGroup
                android:id="@+id/rgMood"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton android:id="@+id/rbMoodGreat"
                    android:layout_width="0dp" android:layout_height="48dp"
                    android:layout_weight="1" android:text="🔥 Great"
                    android:tag="great" android:gravity="center"
                    android:button="@null" android:textSize="11sp"
                    android:background="@drawable/selector_gender_btn"
                    android:layout_marginEnd="4dp"/>
                <RadioButton android:id="@+id/rbMoodOkay"
                    android:layout_width="0dp" android:layout_height="48dp"
                    android:layout_weight="1" android:text="👍 Okay"
                    android:tag="okay" android:gravity="center"
                    android:button="@null" android:textSize="11sp"
                    android:background="@drawable/selector_gender_btn"
                    android:layout_marginEnd="4dp"/>
                <RadioButton android:id="@+id/rbMoodTired"
                    android:layout_width="0dp" android:layout_height="48dp"
                    android:layout_weight="1" android:text="😴 Tired"
                    android:tag="tired" android:gravity="center"
                    android:button="@null" android:textSize="11sp"
                    android:background="@drawable/selector_gender_btn"
                    android:layout_marginEnd="4dp"/>
                <RadioButton android:id="@+id/rbMoodStressed"
                    android:layout_width="0dp" android:layout_height="48dp"
                    android:layout_weight="1" android:text="😤 Stressed"
                    android:tag="stressed" android:gravity="center"
                    android:button="@null" android:textSize="11sp"
                    android:background="@drawable/selector_gender_btn"/>
            </RadioGroup>

        </LinearLayout>

        <!-- SAVE BUTTON -->
        <Button
            android:id="@+id/btnSaveLog"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save Today's Log ✅"
            android:textSize="16sp"/>

    </LinearLayout>
</ScrollView>