<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="#FFFFFF"
    android:padding="16dp"
    android:layout_marginBottom="8dp"
    android:gravity="center_vertical">

    <!-- Day emoji icon -->
    <TextView
        android:id="@+id/tvPlanDayIcon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:text="💪"
        android:textSize="22sp"
        android:gravity="center"
        android:background="#E8F5E9"
        android:layout_marginEnd="16dp"/>

    <!-- Day info: label + focus -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvPlanDayLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today"
            android:textSize="13sp"
            android:textColor="#9E9E9E"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/tvPlanDayFocus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upper Body Strength"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvPlanDayReasoning"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Maintaining current training load."
            android:textSize="12sp"
            android:textColor="#757575"
            android:lineSpacingMultiplier="1.3"/>

    </LinearLayout>

    <!-- Right side: intensity + duration -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <TextView
            android:id="@+id/tvPlanDayIntensity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Moderate"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvPlanDayDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="45 min"
            android:textSize="12sp"
            android:textColor="#757575"/>

    </LinearLayout>

</LinearLayout>