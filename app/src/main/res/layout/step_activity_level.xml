<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <RadioGroup
        android:id="@+id/rgActivityLevel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/rbSedentary"
            style="@style/ActivityLevelOption"
            android:text="🪑  Sedentary — desk job, little exercise"
            android:tag="sedentary"/>

        <RadioButton
            android:id="@+id/rbLight"
            style="@style/ActivityLevelOption"
            android:text="🚶  Light — exercise 1–3 days/week"
            android:tag="light"/>

        <RadioButton
            android:id="@+id/rbModerate"
            style="@style/ActivityLevelOption"
            android:text="🏃  Moderate — exercise 3–5 days/week"
            android:tag="moderate"/>

        <RadioButton
            android:id="@+id/rbActive"
            style="@style/ActivityLevelOption"
            android:text="💪  Active — hard exercise 6–7 days/week"
            android:tag="active"/>

        <RadioButton
            android:id="@+id/rbVeryActive"
            style="@style/ActivityLevelOption"
            android:text="🔥  Very Active — physical job + training"
            android:tag="very_active"/>

    </RadioGroup>

</LinearLayout>