<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml
    This is the LAUNCH screen — shown briefly while MainActivity:
    1. Checks if the user has completed onboarding
    2. Checks if a weekly plan is needed
    3. Routes to the right screen

    It's intentionally minimal — the user sees this for less than
    a second normally. The ProgressBar appears only when background
    work (plan generation/copy) takes a moment.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_surface">

    <!-- App name / logo -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="💪"
        android:textSize="64sp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/tvAppName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FitAI"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/md_theme_primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your AI fitness coach"
        android:textSize="14sp"
        android:textColor="@color/md_theme_onSurfaceVariant"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvAppName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!--
        Loading spinner — GONE by default.
        Only shown while plan generation/copy is running
        (after user makes a choice in the weekly dialog).
    -->
    <ProgressBar
        android:id="@+id/pbMainLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginBottom="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>