<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="#FFFFFF"
    android:padding="16dp"
    android:layout_marginBottom="8dp"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/tvWorkoutIcon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:text="💪"
        android:textSize="22sp"
        android:gravity="center"
        android:background="#E8F5E9"
        android:layout_marginEnd="16dp"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvWorkoutType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Strength"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/tvWorkoutDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mon, Mar 10"
            android:textSize="12sp"
            android:textColor="#9E9E9E"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <TextView
            android:id="@+id/tvWorkoutDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="45 min"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:layout_marginBottom="2dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvWorkoutCalories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="320 kcal"
                android:textSize="11sp"
                android:textColor="#757575"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvIntensityDots"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="●●●○○"
                android:textSize="10sp"
                android:textColor="#4CAF50"/>

        </LinearLayout>
    </LinearLayout>

</LinearLayout>