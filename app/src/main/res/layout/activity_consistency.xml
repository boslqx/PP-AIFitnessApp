<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Consistency Score"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Last 7 days overview"
            android:textSize="13sp"
            android:textColor="#9E9E9E"
            android:layout_marginBottom="20dp"/>

        <!-- WEEKLY SCORE CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1B5E20"
            android:padding="24dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WEEKLY AVERAGE"
                android:textSize="11sp"
                android:textColor="#A5D6A7"
                android:textAllCaps="true"
                android:letterSpacing="0.15"
                android:layout_marginBottom="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tvWeeklyScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="64sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" / 100"
                    android:textSize="18sp"
                    android:textColor="#81C784"
                    android:layout_marginBottom="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STREAK"
                        android:textSize="10sp"
                        android:textColor="#A5D6A7"
                        android:letterSpacing="0.1"/>
                    <TextView
                        android:id="@+id/tvStreakCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 days 🔥"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TREND"
                        android:textSize="10sp"
                        android:textColor="#A5D6A7"
                        android:letterSpacing="0.1"/>
                    <TextView
                        android:id="@+id/tvWeekTrend"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="stable →"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BURNOUT"
                        android:textSize="10sp"
                        android:textColor="#A5D6A7"
                        android:letterSpacing="0.1"/>
                    <TextView
                        android:id="@+id/tvBurnoutRiskBig"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LOW"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- 7-DAY BAR CHART (custom view) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:elevation="2dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daily Breakdown"
                android:textSize="14sp"
                android:textColor="#757575"
                android:layout_marginBottom="16dp"/>

            <!-- Bar chart: 7 bars built programmatically in Activity -->
            <LinearLayout
                android:id="@+id/barChartContainer"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:layout_marginBottom="8dp"/>

            <!-- Day labels row -->
            <LinearLayout
                android:id="@+id/dayLabelsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"/>

        </LinearLayout>

        <!-- SCORE BREAKDOWN LEGEND -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:elevation="2dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="How Your Score is Calculated"
                android:textSize="14sp"
                android:textColor="#757575"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="✅  Task completion"
                    android:textSize="13sp" android:textColor="#424242"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Base factor" android:textSize="12sp" android:textColor="#9E9E9E"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="💪  Workout intensity"
                    android:textSize="13sp" android:textColor="#424242"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="×0.8 – ×1.2" android:textSize="12sp" android:textColor="#9E9E9E"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="🔥  Streak multiplier"
                    android:textSize="13sp" android:textColor="#424242"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="up to ×2.0" android:textSize="12sp" android:textColor="#9E9E9E"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="😴  Sleep quality"
                    android:textSize="13sp" android:textColor="#424242"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="×0.6 – ×1.1" android:textSize="12sp" android:textColor="#9E9E9E"/>
            </LinearLayout>

        </LinearLayout>

        <!-- COACH MESSAGE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E8F5E9"
            android:padding="20dp"
            android:elevation="2dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🤖  AI COACH"
                android:textSize="11sp"
                android:textColor="#388E3C"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvCoachMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textSize="14sp"
                android:textColor="#1B5E20"
                android:lineSpacingMultiplier="1.5"/>
        </LinearLayout>

        <!-- BACK BUTTON -->
        <Button
            android:id="@+id/btnBackFromConsistency"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:text="← Back to Dashboard"/>

    </LinearLayout>
</ScrollView>