<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Progress"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your trends over time"
            android:textSize="13sp"
            android:textColor="#9E9E9E"
            android:layout_marginBottom="20dp"/>

        <!-- TAB ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:elevation="2dp"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnTabWeight"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="⚖️ Weight"
                android:textSize="12sp"
                style="@style/Widget.Material3.Button.TextButton"/>

            <Button
                android:id="@+id/btnTabCalories"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="🔥 Calories"
                android:textSize="12sp"
                style="@style/Widget.Material3.Button.TextButton"/>

            <Button
                android:id="@+id/btnTabSleep"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="😴 Sleep"
                android:textSize="12sp"
                style="@style/Widget.Material3.Button.TextButton"/>

        </LinearLayout>

        <!-- CHART CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvChartTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Weight (kg)"
                android:textSize="14sp"
                android:textColor="#757575"
                android:layout_marginBottom="12dp"/>

            <!-- Our custom chart view -->
            <com.example.aifitnessapp.ui.progress.ProgressChartView
                android:id="@+id/chartView"
                android:layout_width="match_parent"
                android:layout_height="220dp"/>

        </LinearLayout>

        <!-- SUMMARY CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E8F5E9"
            android:padding="20dp"
            android:elevation="2dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊  ANALYSIS"
                android:textSize="11sp"
                android:textColor="#388E3C"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textSize="14sp"
                android:textColor="#1B5E20"
                android:lineSpacingMultiplier="1.4"/>

        </LinearLayout>

        <!-- STAT TILES ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <!-- Tile 1 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:elevation="2dp"
                android:gravity="center"
                android:layout_marginEnd="6dp">

                <TextView
                    android:id="@+id/tvStatLabel1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="START"
                    android:textSize="10sp"
                    android:textColor="#9E9E9E"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tvStatVal1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#212121"/>

            </LinearLayout>

            <!-- Tile 2 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:elevation="2dp"
                android:gravity="center"
                android:layout_marginEnd="6dp">

                <TextView
                    android:id="@+id/tvStatLabel2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LATEST"
                    android:textSize="10sp"
                    android:textColor="#9E9E9E"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tvStatVal2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#212121"/>

            </LinearLayout>

            <!-- Tile 3 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:elevation="2dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvStatLabel3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CHANGE"
                    android:textSize="10sp"
                    android:textColor="#9E9E9E"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tvStatVal3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#212121"/>

            </LinearLayout>

        </LinearLayout>

        <!-- BACK BUTTON -->
        <Button
            android:id="@+id/btnBackFromProgress"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:text="← Back to Dashboard"/>

    </LinearLayout>
</ScrollView>