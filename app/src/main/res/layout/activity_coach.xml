<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_surface"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingBottom="88dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- HEADER -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🤖  AI COACH"
                android:textSize="11sp"
                android:textColor="@color/md_theme_primary"
                android:textAllCaps="true"
                android:letterSpacing="0.15"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your AI Fitness Coach"
                android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                android:textColor="@color/md_theme_onSurface"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvCoachWeekLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Week summary"
                android:textSize="13sp"
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:layout_marginBottom="24dp"/>

            <!-- LOADING STATE -->
            <LinearLayout
                android:id="@+id/loadingState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="48dp"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🤖"
                    android:textSize="48sp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Analysing your week..."
                    android:textSize="15sp"
                    android:textColor="@color/md_theme_onSurfaceVariant"/>

            </LinearLayout>

            <!-- CONTENT STATE -->
            <LinearLayout
                android:id="@+id/contentState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- COACH MESSAGE CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/md_theme_primary"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="COACH SAYS"
                            android:textSize="10sp"
                            android:textColor="#C8D3FF"
                            android:textAllCaps="true"
                            android:letterSpacing="0.15"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:id="@+id/tvCoachMessage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Loading..."
                            android:textSize="15sp"
                            android:textColor="#FFFFFF"
                            android:lineSpacingMultiplier="1.5"/>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- THIS WEEK CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/md_theme_outlineVariant"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="THIS WEEK"
                            android:textSize="11sp"
                            android:textColor="@color/md_theme_onSurfaceVariant"
                            android:textAllCaps="true"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="12dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:id="@+id/tvCompletionFraction"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="0 / 4 workouts done"
                                android:textSize="15sp"
                                android:textColor="@color/md_theme_onSurface"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/tvCompletionRate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0%"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="@color/md_theme_primary"/>

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvCompletionBar"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="░░░░░░░░░░"
                            android:textSize="18sp"
                            android:textColor="@color/md_theme_primary"
                            android:fontFamily="monospace"
                            android:layout_marginBottom="16dp"/>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/md_theme_outlineVariant"
                            android:layout_marginBottom="16dp"/>

                        <!-- Streak row -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="STREAK"
                            android:textSize="11sp"
                            android:textColor="@color/md_theme_onSurfaceVariant"
                            android:textAllCaps="true"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="6dp"/>

                        <TextView
                            android:id="@+id/tvStreak"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔥 0 sessions"
                            android:textSize="15sp"
                            android:textColor="@color/md_theme_onSurface"/>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- EFFORT CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/md_theme_outlineVariant"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AVERAGE EFFORT"
                            android:textSize="11sp"
                            android:textColor="@color/md_theme_onSurfaceVariant"
                            android:textAllCaps="true"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="12dp"/>

                        <TextView
                            android:id="@+id/tvAvgEffort"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/md_theme_onSurface"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:id="@+id/tvEffortBar"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="░░░░░░░░░░"
                            android:textSize="18sp"
                            android:textColor="#FF9800"
                            android:fontFamily="monospace"/>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ADAPTATION CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/md_theme_surfaceContainer"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="NEXT WEEK"
                                android:textSize="11sp"
                                android:textColor="@color/md_theme_onSurfaceVariant"
                                android:textAllCaps="true"
                                android:letterSpacing="0.1"/>

                            <TextView
                                android:id="@+id/tvAdaptationStrategy"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="✅ On Track"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/md_theme_primary"/>

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvAdaptationNotice"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Loading..."
                            android:textSize="14sp"
                            android:textColor="@color/md_theme_onSurface"
                            android:lineSpacingMultiplier="1.5"
                            android:layout_marginBottom="12dp"/>

                        <TextView
                            android:id="@+id/tvNextIntensity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Next week intensity: Moderate"
                            android:textSize="13sp"
                            android:textColor="@color/md_theme_onSurfaceVariant"/>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- BACK BUTTON -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBackFromCoach"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_margin="16dp"
        android:text="← Back to Home"
        android:textAllCaps="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>